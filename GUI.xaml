<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AD Manager Dashboard" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid>

        <!-- ================= LOGIN PANEL ================= -->
        <Grid x:Name="LoginPanel">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="300">
                <TextBlock Text="Benutzername" Margin="0,0,0,5"/>
                <TextBox x:Name="txtUser" Margin="0,0,0,10"/>
                <TextBlock Text="Kennwort" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPass" Margin="0,0,0,10"/>
                <Button x:Name="btnLogin" Content="Login" Width="100" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ================= MAIN GRID ================= -->
        <Grid x:Name="MainGrid" Visibility="Collapsed" Margin="5">
            <TabControl x:Name="MainTabControl">

                <!-- ================= TAB1 – Übersicht ================= -->
                <TabItem Header="Übersicht" Name="TabOverview">
                    <Grid Margin="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Suche -->
                        <Grid Grid.Row="0" Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Benutzer-Suche -->
                            <TextBox x:Name="UserSearchBox" Grid.Column="0" Margin="0,0,5,0"/>
                            <Button x:Name="BtnUserSearch" Grid.Column="1" Content="Benutzer suchen" Width="130"/>

                            <!-- Computersuche -->
                            <TextBox x:Name="ComputerSearchBox" Grid.Column="2" Margin="10,0,5,0"/>
                            <Button x:Name="BtnComputerSearch" Grid.Column="3" Content="Computer suchen" Width="130"/>
                        </Grid>

                        <!-- Listen -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5">
                            <ListBox x:Name="UserListBox" Width="450" Height="160" DisplayMemberPath="DisplayText"/>
                            <ListBox x:Name="ComputerListBox" Width="450" Height="160" Margin="10,0,0,0" DisplayMemberPath="Name"/>
                        </StackPanel>

                        <!-- Aktionen -->
                        <StackPanel Grid.Row="2" Margin="5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Button x:Name="BtnEditUser" Content="Benutzer anpassen" Width="120" Height="20" Margin="0,0,10,0" Grid.Column="0"/>
                                <Button x:Name="BtnUnlock" Content="Entsperren" Width="120" Margin="5" Grid.Column="1"/>
                                <Button x:Name="BtnEnable" Content="Aktivieren" Width="120" Margin="5" Grid.Column="2"/>
                                <Button x:Name="BtnDisable" Content="Deaktivieren &amp; Verschieben" Width="180" Margin="5" Grid.Column="3"/>
                                <Button x:Name="BtnResetPwd" Content="Kennwort zurücksetzen" Width="160" Margin="5" Grid.Column="4"/>
                                <Button x:Name="BtnTeamviewer" Content="TeamViewer starten" Width="120" Margin="5" Grid.Column="5"/>
                            </Grid>
                        </StackPanel>

                        <!-- Sessions -->
                        <GroupBox Grid.Row="3" Header="Aktive Sessions" Margin="5">
                            <DataGrid x:Name="dgSessions" AutoGenerateColumns="False" CanUserAddRows="False"
                                        MaxHeight="120" ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Terminalserver" Binding="{Binding HostedMachineName}" Width="150"/>
                                    <DataGridTextColumn Header="Applikation" Binding="{Binding LaunchedViaPublishedName}" Width="150"/>
                                    <DataGridTextColumn Header="AppState" Binding="{Binding AppState}" Width="100"/>
                                    <DataGridTextColumn Header="ClientName" Binding="{Binding ClientName}" Width="120"/>
                                    <DataGridTextColumn Header="ClientIP" Binding="{Binding ClientAddress}" Width="120"/>
                                    <DataGridTextColumn Header="StartTime" Binding="{Binding StartTime}" Width="150"/>
                                    <DataGridTextColumn Header="SessionState" Binding="{Binding SessionState}" Width="100"/>
                                    <DataGridTextColumn Header="UserFullName" Binding="{Binding UserFullName}" Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <!-- Citrix Abmelden -->
                        <StackPanel Grid.Row="4" Margin="5">
                            <Button x:Name="BtnCitrixLogoff" Content="Citrix abmelden" Width="140" HorizontalAlignment="Left"/>
                        </StackPanel>

                        <!-- Gruppen -->
                        <GroupBox Grid.Row="5" Header="Gruppenverwaltung" Margin="5">
                            <StackPanel Orientation="Horizontal">
                                <ListBox x:Name="GroupListBox" Width="400" ScrollViewer.VerticalScrollBarVisibility="Auto" Height="150" DisplayMemberPath="Name"/>
                                <StackPanel Margin="10,0,0,0">
                                    <Button x:Name="BtnAddGroup" Content="Zur Gruppe hinzufügen" Width="170" Margin="0,0,0,5"/>
                                    <Button x:Name="BtnRemoveGroup" Content="Gruppe entfernen" Width="170"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>

        <!-- ================= STATUSBAR ================= -->
        <StatusBar VerticalAlignment="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Bereit"/>
            </StatusBarItem>
        </StatusBar>

    </Grid>
</Window>